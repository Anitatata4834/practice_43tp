<Window x:Class="Task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task1"
        mc:Ignorable="d"
        Title="Учет сотрудников" Height="450" Width="627">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="White"/>
            <GradientStop Color="White" Offset="1"/>
            <GradientStop Color="Black" Offset="0.5"/>
            <GradientStop Color="White"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid Margin="10,27,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="601*"/>
            <ColumnDefinition Width="179*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="127*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Фильтр по должности" BorderBrush="#FF6C6B6B" Height="42" VerticalAlignment="Top" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Все" IsChecked="True" Checked="FilterChanged"/>
                <RadioButton Content="Программист" Margin="10 0" Checked="FilterChanged"/>
                <RadioButton Content="Архитектор" Margin="10 0" Checked="FilterChanged"/>
                <RadioButton Content="Менеджер" Margin="10 0" Checked="FilterChanged"/>
            </StackPanel>
        </GroupBox>
        <ListView x:Name="EmployeeList" Margin="0,57,0,0" Foreground="Black" Grid.RowSpan="2" Height="330" VerticalAlignment="Top" Grid.ColumnSpan="2" HorizontalAlignment="Left" Width="607">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ФИО" DisplayMemberBinding="{Binding FullName}" Width="300"/>
                    <GridViewColumn Header="Должность" DisplayMemberBinding="{Binding Position}" Width="300"/>
                </GridView>
            </ListView.View>
        </ListView>
        <Menu Margin="-10,-27,-10,0" Grid.ColumnSpan="2" Height="20" VerticalAlignment="Top" Background="White">
            <MenuItem Header="Файл"></MenuItem>
            <MenuItem Header="Сотрудники">
                <MenuItem Header="Добавить сотрудника" Click="AddEmployee_Click"
                          Command="{Binding AddEmployeeCommand}"/>
                <MenuItem Header="Редактировать сотрудника" Click="EditEmployee_Click"
                          Command="{Binding EditEmployeeCommand}"/>
                <MenuItem Header="Удалить сотрудника" Click="DeleteEmployee_Click"
                          Command="{Binding DeleteEmployeeCommand}"/>
            </MenuItem>
            <MenuItem Header="Отчеты"></MenuItem>
            <MenuItem Header="Настройки"></MenuItem>
        </Menu>
    </Grid>
</Window>
