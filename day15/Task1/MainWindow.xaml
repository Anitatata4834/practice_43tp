<Window x:Class="Task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task1"
        mc:Ignorable="d"
        Title="Учет сотрудников" Height="450" Width="627">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="White"/>
            <GradientStop Color="White" Offset="1"/>
            <GradientStop Color="Black" Offset="0.5"/>
            <GradientStop Color="White"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid Margin="10,27,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="468*"/>
            <ColumnDefinition Width="139*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="127*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Фильтр по должности" BorderBrush="#FF6C6B6B" Height="42" VerticalAlignment="Top" Margin="0,0,5,0">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Все" IsChecked="True" Checked="FilterChanged"/>
                <RadioButton Content="Программист" Margin="10 0" Checked="FilterChanged"/>
                <RadioButton Content="Архитектор" Margin="10 0" Checked="FilterChanged"/>
                <RadioButton Content="Менеджер" Margin="10 0" Checked="FilterChanged"/>
            </StackPanel>
        </GroupBox>
        <ListView x:Name="EmployeeList" ItemsSource="{Binding Employees}" Margin="0,57,0,10" Foreground="Black" Grid.RowSpan="2" Grid.ColumnSpan="2" HorizontalAlignment="Left" Width="607">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding Position}"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Menu Margin="-10,-27,-10,0" Grid.ColumnSpan="2" Height="20" VerticalAlignment="Top" Background="White">
            <MenuItem Header="Файл"></MenuItem>
            <MenuItem Header="Сотрудники">
                <MenuItem Header="Добавить сотрудника" Click="AddEmployee_Click"
                          Command="{Binding AddEmployeeCommand}"/>
                <MenuItem Header="Редактировать сотрудника" Click="EditEmployee_Click"
                          Command="{Binding EditEmployeeCommand}"/>
                <MenuItem Header="Удалить сотрудника" Click="DeleteEmployee_Click"
                          Command="{Binding DeleteEmployeeCommand}"/>
            </MenuItem>
            <MenuItem Header="Отчеты"></MenuItem>
            <MenuItem Header="Настройки"></MenuItem>
        </Menu>
        <ComboBox x:Name="DepartmentCombo" ItemsSource="{Binding Departments}" DisplayMemberPath="Name" Grid.Column="1" Margin="6,14,0,0" VerticalAlignment="Top" Height="22"/>
        <ProgressBar x:Name="LoadingBar" Visibility="Collapsed" Margin="206,0,68,186" Grid.Row="1" Height="22" VerticalAlignment="Bottom" IsIndeterminate="True" Foreground="#FF0088FF" Background="White"/>
    </Grid>
</Window>
