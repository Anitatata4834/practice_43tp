<Window x:Class="Task1.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task1"
        mc:Ignorable="d"
        Title="LoginView" Height="247" Width="319">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Логин:" FontSize="14"/>
        <TextBox Grid.Row="1"
                 Height="25"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="2" Text="Пароль:" Margin="0,10,0,0" FontSize="14"/>
        <PasswordBox Grid.Row="3"
                     Height="25"
                     PasswordChanged="PasswordBox_PasswordChanged"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,17,0,0" HorizontalAlignment="Center" Height="55" VerticalAlignment="Top">
            <Button Content="Войти"
                    Width="100" Height="30" Margin="5"
                    Command="{Binding LoginCommand}" Background="Black" Foreground="White"/>

            <Button Content="Регистрация"
                    Width="100" Height="30" Margin="5"
                    Command="{Binding RegisterCommand}" Foreground="White" Background="Black"/>
        </StackPanel>

        <TextBlock Grid.Row="5"
                   Text="{Binding StatusMessage}"
                   Foreground="Red"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>
