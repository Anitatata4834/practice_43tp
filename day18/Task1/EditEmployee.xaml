<Window x:Class="Task1.EditEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task1"
        mc:Ignorable="d"
        Title="Редактировать информацию" Height="199" Width="326">
    <Grid RenderTransformOrigin="0.501,0.416" Margin="10,10,10,0" Height="90" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="86"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="1" Height="86" VerticalAlignment="Center">
            <TextBlock Text="ФИО:"/>
            <TextBox Text="{Binding FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Name="FullNameBox" Margin="0 5"/>
            <TextBlock Text="Должность:"/>
            <TextBox Text="{Binding Position, Mode=OneWay}" Name="PositionBox" Margin="0 5" Height="19"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Width="142" VerticalAlignment="Bottom" Margin="73,0,0,-50" Height="40">
            <Button Content="Редактировать" Width="120" Margin="10" Background="Black"  Foreground="White" Click="EditEmployee_Click"/>
        </StackPanel>
        
    </Grid>
</Window>