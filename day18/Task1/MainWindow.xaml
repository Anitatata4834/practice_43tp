<Window x:Class="Task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task1"
        mc:Ignorable="d"
        Title="Учет сотрудников" Height="450" Width="627">

    <Window.Resources>
        <Style x:Key="PulseAnimation" TargetType="Ellipse">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Fill" Value="Gray"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                    <Setter Property="Fill" Value="LimeGreen"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                    From="1" To="1.25" Duration="0:0:0.4"/>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                    From="1" To="1.25" Duration="0:0:0.4"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="White"/>
            <GradientStop Color="White" Offset="1"/>
            <GradientStop Color="Black" Offset="0.5"/>
            <GradientStop Color="White"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="10,27,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="127*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Фильтр по должности" BorderBrush="#FF6C6B6B" Height="42" VerticalAlignment="Top" Margin="0,0,144,0">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Все" IsChecked="True" Checked="FilterChanged"/>
                <RadioButton Content="Программист" Margin="10 0" Checked="FilterChanged"/>
                <RadioButton Content="Архитектор" Margin="10 0" Checked="FilterChanged"/>
                <RadioButton Content="Менеджер" Margin="10 0" Checked="FilterChanged"/>
            </StackPanel>
        </GroupBox>

        <ListView x:Name="EmployeeList" ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}" Margin="0,77,0,10" Foreground="Black" Grid.RowSpan="2">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                 
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="5"
                        MouseLeftButtonUp="EmployeeItem_Click"
                        Grid.Row="0">

                            <Ellipse Width="12" Height="12" Margin="0,4,8,0"
                         Style="{StaticResource PulseAnimation}"/>

                            <StackPanel>
                                <TextBlock Text="{Binding FullName}" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Position}" FontSize="12" Foreground="Gray"/>
                            </StackPanel>
                        </StackPanel>

                        <Border x:Name="DetailsPanel"
                    Background="#FFF7F7F7"
                    CornerRadius="4"
                    Margin="25,0,0,5"
                    Padding="10"
                    Height="0"
                    Opacity="0"
                    ClipToBounds="True"
                    Grid.Row="1">

                            <StackPanel>
                                <TextBlock Text="ФИО:" FontWeight="Bold"/>
                                <TextBlock Text="{Binding FullName}" Margin="0,0,0,5"/>
                                <TextBlock Text="Дополнительная информация..." Foreground="Gray"/>
                            </StackPanel>
                        </Border>

                    </Grid>

                    <DataTemplate.Triggers>

                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}"
                         Value="True">

                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="DetailsPanel"
                                             Storyboard.TargetProperty="Height"
                                             To="80" Duration="0:0:0.25"/>

                                        <DoubleAnimation Storyboard.TargetName="DetailsPanel"
                                             Storyboard.TargetProperty="Opacity"
                                             To="1" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>

                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="DetailsPanel"
                                             Storyboard.TargetProperty="Height"
                                             To="0" Duration="0:0:0.25"/>

                                        <DoubleAnimation Storyboard.TargetName="DetailsPanel"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>

                        </DataTrigger>

                    </DataTemplate.Triggers>

                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

        <Menu Margin="-10,-27,-10,0" Height="20" VerticalAlignment="Top" Background="White">
            <MenuItem Header="Файл"></MenuItem>
            <MenuItem Header="Сотрудники">
                <MenuItem Header="Добавить сотрудника" Click="AddEmployee_Click"
                          Command="{Binding AddEmployeeCommand}"/>
                <MenuItem Header="Редактировать сотрудника" Click="EditEmployee_Click"
                          Command="{Binding EditEmployeeCommand}"/>
                <MenuItem Header="Удалить сотрудника" Click="DeleteEmployee_Click"
                           Command="{Binding FireEmployeeCommand}"/>
            </MenuItem>
            <MenuItem Header="Отчеты"></MenuItem>
            <MenuItem Header="Настройки"></MenuItem>
            <MenuItem Header="Чат" Click="OpenChat_Click"/>
            <MenuItem Header="Уведомления" Click="OpenNotifications_Click"/>
        </Menu>

        <ComboBox x:Name="DepartmentCombo" ItemsSource="{Binding Departments}" DisplayMemberPath="Name" Margin="0,14,0,0" VerticalAlignment="Top" Height="22" HorizontalAlignment="Right" Width="133" BorderBrush="#FFACACAC">
            <ComboBox.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </ComboBox.Background>
        </ComboBox>
        <ProgressBar x:Name="LoadingBar" Visibility="Collapsed" Margin="206,36,207,0" Grid.Row="1" Height="22" VerticalAlignment="Top" IsIndeterminate="True" Foreground="#FF0088FF" Background="White"/>

        <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" Background="White" Margin="0,47,144,0" Height="21" VerticalAlignment="Top"/>
        <TextBlock x:Name="SearchPlaceholder" Text="Поиск сотрудника" Foreground="Gray" Margin="8,49,0,0" IsHitTestVisible="False" Opacity="0.6" Height="16" VerticalAlignment="Top" HorizontalAlignment="Left" Width="455"/>
    </Grid>
</Window>