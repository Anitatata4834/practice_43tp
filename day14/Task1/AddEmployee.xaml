<Window x:Class="Task1.AddEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task1"
        mc:Ignorable="d"
        Title="Добавить сотрудника" Height="199" Width="326">
    <Window.Resources>
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Black" CornerRadius="10">
                            <ContentPresenter Content="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid RenderTransformOrigin="0.501,0.416" Margin="10,10,10,0" Height="90" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="86"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="1" Height="86" VerticalAlignment="Center">
            <TextBlock Text="ФИО:"/>
            <TextBox Name="FullNameBox" Margin="0 5"/>
            <TextBlock Text="Должность:"/>
            <TextBox Name="PositionBox" Margin="0 5" Height="19"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Width="142" VerticalAlignment="Bottom" Margin="73,0,0,-50" Height="40">
            <Button Style="{StaticResource AddButtonStyle}" Content="Добавить" Width="120" Margin="10" Background="Black"  Foreground="White" Click="AddEmployee_Click"/>
        </StackPanel>
    </Grid>
</Window>
